generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  lose_weight
  build_muscle
  maintain
}

enum FitnessLevel {
  beginner
  intermediate
}

enum Equipment {
  none
  home
  gym
}

enum ExerciseCategory {
  upper
  lower
  full_body
  core
  cardio
}

enum PlanDayType {
  workout
  rest
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  workoutPlans  WorkoutPlan[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  goal              Goal?
  fitnessLevel      FitnessLevel?
  equipment         Equipment?
  trainingFrequency Int?
  setupCompleted    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  equipment   Equipment
  level       FitnessLevel
  category    ExerciseCategory
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id          String       @id @default(cuid())
  userId      String
  goal        Goal
  fitnessLevel FitnessLevel
  equipment   Equipment
  trainingFrequency Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays WorkoutDay[]
}

model WorkoutDay {
  id          String       @id @default(cuid())
  workoutPlanId String
  dayIndex    Int
  dayLabel    String
  type        PlanDayType
  category    ExerciseCategory?
  guidance    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workoutPlan WorkoutPlan  @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercises   WorkoutExercise[]

  @@unique([workoutPlanId, dayIndex])
}

model WorkoutExercise {
  id          String      @id @default(cuid())
  workoutDayId String
  exerciseId  String
  sortOrder   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workoutDay  WorkoutDay  @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([workoutDayId, sortOrder])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
